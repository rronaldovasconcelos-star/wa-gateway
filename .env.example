# ---- Gateway ----
PORT=8090
# Chave que os PROJETOS usam para falar com o gateway (header: x-gw-key).
GW_API_KEY=troque-esta-chave

# ---- Evolution (real) — fica SÓ aqui dentro ----
EVOLUTION_URL=http://evolution:8080
EVOLUTION_APIKEY=sua-apikey-real-da-evolution

# ---- Banco (SQLite) ----
DATABASE_URL=file:./data/gateway.db

# ---- Faixa transacional (síncrona) ----
# Balde de tokens: permite pequenas rajadas, mas com gap mínimo.
TX_BUCKET_CAPACITY=3
TX_REFILL_PER_SEC=0.34          # ~1 token a cada 3s
TX_MAX_WAIT_MS=10000            # espera máx. por um token antes de 429

# ---- Faixa bulk (fila com drip) ----
BULK_MIN_GAP_MS=8000            # intervalo mínimo entre 2 envios de lote
BULK_MAX_GAP_MS=20000           # intervalo máximo (jitter entre min e max)
BULK_MAX_ATTEMPTS=4             # tentativas por mensagem antes de FAILED

# ---- Teto diário / warmup (por instância) ----
# Curva por idade (dias desde warmupStart). CSV de tetos; último valor = regime.
WARMUP_CURVE=20,40,80,160,320,500
# Teto de regime (após a curva acabar).
DAILY_CAP_REGIME=500

# ---- Kill-switch ----
CIRCUIT_FAILURE_THRESHOLD=5     # falhas seguidas -> pausa a instância
# Alerta de kill-switch por WhatsApp (enviado direto pela Evolution, fora da fila).
ALERT_INSTANCE=csp-portal       # instância SÃ usada só para mandar o alerta
ALERT_TO=5531999999999          # número do admin que recebe o alerta
